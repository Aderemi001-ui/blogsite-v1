<body>
     <form style="display: flex;flex-direction: column; gap: 10px;margin-top: 100px;" id="form" method="POST" > 
            <h1 class="h3 mb-3 fw-normal" style="text-align: center;">Please sign in</h1>
             <div class="form-floating mx-5" >
                 <input type="text" class="form-control " name="user"  required   id="floatingInput" placeholder="name@example.com">
                 <label for="floatingInput"  class="floatingInput">Admin username</label> 
                </div>
                  <div class="form-floating mx-5"> 
                    <input type="password" class="form-control " required  id="floatingPassword"  placeholder="Password"> 
                    <label for="floatingPassword" name="pass"  class="floatingInput" >Password</label>
                 </div>
                 <button class="btn btn-primary" id="login" class="btn" >Sign in</button>
                 </form>
                 <dialog class="modal" name="dialog"></dialog>
<style>
